# ===========================================
# Raad LMS Frontend Environment Configuration
# ===========================================
#
# In the browser, API calls use window.location.origin (same-origin on port 80).
# VITE_APP_URL is used at build time for metadata; set to your public URL.

VITE_APP_NAME="Raad LMS"
VITE_APP_URL=http://localhost

# Set to "true" to bypass permission checks (DEV ONLY!)
VITE_DISABLE_AUTH=false
