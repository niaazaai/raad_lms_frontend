{
  "name": "raad-lms-frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "bunx --bun vite",
    "build": "bunx --bun tsc --noEmit -p tsconfig.app.json && bunx --bun vite build",
    "check": "bunx --bun tsc --noEmit -p tsconfig.app.json --extendedDiagnostics",
    "lint": "bunx --bun eslint .",
    "format": "bunx --bun prettier --write 'src/**/*.{js,jsx,ts,tsx,json,css,md}'",
    "preview": "bunx --bun vite preview --port 3000"
  },
