    "@eslint/js": "^9.39.1",
    "@tanstack/eslint-plugin-query": "^5.74.7",
    "@types/node": "^22.13.10",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react-swc": "^4.2.0",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.1",
    "eslint-plugin-prettier": "^5.2.3",
